import os
from configparser import ConfigParser

def load_config(env=None):
    env = env or os.getenv("ENVIRONMENT", "dev")
    config = ConfigParser()
    config.read(f"config.{env}.ini")
    return config

# ====================
# File Operations
# ====================
import yaml

def read_yaml(filepath):
    with open(filepath, 'r') as f:
        return yaml.safe_load(f)

def write_yaml(data, filepath):
    with open(filepath, 'w') as f:
        yaml.safe_dump(data, f)

# ====================
# Graceful Shutdown
# ====================
import signal

def graceful_shutdown(signum, frame):
    logger.info("Received shutdown signal, cleaning up...")
    # Cleanup logic
    sys.exit(0)

signal.signal(signal.SIGTERM, graceful_shutdown)
# Handle SIGINT (Ctrl+C) for graceful shutdown in interactive environments
signal.signal(signal.SIGINT, graceful_shutdown)

# ==================== IMPORTANT NOTES ====================
# 1. SIGTERM vs SIGINT:
#    - SIGTERM: Used by container orchestrators (K8s) and process managers
#    - SIGINT: Triggered by Ctrl+C in terminal (development/debugging)
#    - Always handle BOTH in production applications
#
# 2. Shutdown Handler Best Practices:
#    - Keep the handler simple and fast (avoid long operations)
#    - Use threading for long cleanup tasks
#    - Close DB connections, flush logs, and cancel pending tasks
#
# 3. Graceful Shutdown Workflow:
#    - Stop accepting new requests
#    - Wait for in-flight requests to complete (with timeout)
#    - Close resources (DB, cache, files)
#    - Log final metrics and exit cleanly
#
# 4. Testing Graceful Shutdown:
#    - Test with: kill -SIGTERM <pid> and Ctrl+C
#    - Set reasonable timeouts to prevent zombie processes
#    - Monitor logs for proper cleanup messages
#
# 5. Common Pitfalls to Avoid:
#    - Ignoring SIGTERM in containerized environments
#    - Not setting timeouts on graceful shutdown (risk of hanging)
#    - Blocking the signal handler with heavy operations
#    - Forgetting to close database connections and file handles
#    - Not testing shutdown behavior in production-like conditions
